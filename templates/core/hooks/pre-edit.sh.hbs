#!/bin/bash
# .forge/hooks/pre-edit.sh — PreToolUse hook for Edit|Write
# Blocks file edits without an active bead (enforces tracked work)

INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.file_path // .path // empty' 2>/dev/null)

# If we can't determine the file path, allow (fail open)
if [ -z "$FILE_PATH" ]; then
	exit 0
fi

# Allow harness files, docs, and config — these don't need tracking
case "$FILE_PATH" in
	*.md|*.yaml|*.yml|*.txt|*.gitignore|*.env*) exit 0 ;;
	.forge/*|.claude/*|forge.yaml|CLAUDE.md) exit 0 ;;
	package.json|package-lock.json|tsconfig.json) exit 0 ;;
	pyproject.toml|requirements.txt|go.mod|go.sum) exit 0 ;;
	Cargo.toml|Cargo.lock) exit 0 ;;
esac

# Check if tracking is enforced
ENFORCE=$(grep -oP 'enforce_tracking:\s*\K\w+' forge.yaml 2>/dev/null || echo "true")
if [ "$ENFORCE" != "true" ]; then
	exit 0
fi

# Check for active beads
ACTIVE=$(bash .forge/pipeline/bead-state.sh list-active 2>/dev/null)
if [ -z "$ACTIVE" ] || [ "$ACTIVE" = "[]" ]; then
	echo '{"decision":"block","reason":"No active bead. Run /deliver to start tracked work, or use /deliver --quick for a lightweight change."}'
	exit 0
fi

# Check if this file is locked by another bead
LOCK_STATUS=$(bash .forge/pipeline/bead-state.sh check-file "$FILE_PATH" 2>/dev/null)
if [ "$LOCK_STATUS" = "locked_by_other" ]; then
	echo '{"decision":"block","reason":"File is locked by another bead. Finish or close that work first."}'
	exit 0
fi

# Allow the edit
exit 0
