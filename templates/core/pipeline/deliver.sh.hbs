#!/usr/bin/env bash
# forge pipeline — deliver: branch, commit, push, PR
# Generated by: forge init
set -euo pipefail

FORGE_DIR=".forge"
BEAD_STATE="${FORGE_DIR}/pipeline/bead-state.sh"
PROMPTS_DIR="${FORGE_DIR}/pipeline"

BEAD_ID="${1:-}"
PR_BODY_FILE="${2:-}"

if [[ -z "$BEAD_ID" ]]; then
  echo '{"error":"Usage: deliver.sh <bead-id> [pr-body-file]"}' >&2
  exit 1
fi

# --- Read bead state ---

BEAD_JSON=$(bash "$BEAD_STATE" get "$BEAD_ID")
TITLE=$(echo "$BEAD_JSON" | jq -r '.title // "untitled"')
TIER=$(echo "$BEAD_JSON" | jq -r '.tier // "T1"')
DESCRIPTION=$(echo "$BEAD_JSON" | jq -r '.description // ""')
MODE=$(echo "$BEAD_JSON" | jq -r '.mode // "normal"')

# Get modified files from bead state
MODIFIED_FILES=$(echo "$BEAD_JSON" | jq -r '.files.modified[]? // empty' 2>/dev/null)

# If no files tracked in bead, detect from git
if [[ -z "$MODIFIED_FILES" ]]; then
  MODIFIED_FILES=$(git diff --name-only HEAD 2>/dev/null || true)
  if [[ -z "$MODIFIED_FILES" ]]; then
    MODIFIED_FILES=$(git diff --cached --name-only 2>/dev/null || true)
  fi
  if [[ -z "$MODIFIED_FILES" ]]; then
    MODIFIED_FILES=$(git status --porcelain | grep -v '^\?' | awk '{print $2}')
  fi
fi

if [[ -z "$MODIFIED_FILES" ]]; then
  echo '{"error":"No modified files found to deliver"}' >&2
  exit 1
fi

# --- Generate slug from title ---

slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | \
    sed 's/[^a-z0-9]/-/g' | \
    sed 's/--*/-/g' | \
    sed 's/^-//' | \
    sed 's/-$//' | \
    cut -c1-40
}

SLUG=$(slugify "$TITLE")
BRANCH="feature/${BEAD_ID}-${SLUG}"

# --- Phase 1: Branch + commit + push ---

# If we don't have a PR body yet, do branch+commit+push, then PAUSE for PR body
if [[ -z "$PR_BODY_FILE" ]]; then
  # Create branch (if not already on it)
  CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || echo "")
  if [[ "$CURRENT_BRANCH" != "$BRANCH" ]]; then
    git checkout -b "$BRANCH" 2>/dev/null || git checkout "$BRANCH" 2>/dev/null || {
      echo "{\"error\":\"Failed to create or switch to branch ${BRANCH}\"}" >&2
      exit 1
    }
  fi

  # Stage files explicitly — never git add .
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    if [[ -f "$file" ]]; then
      git add "$file"
    fi
  done <<< "$MODIFIED_FILES"

  # Build commit message
  local_type="feat"
  if echo "$TITLE" | grep -qiE '(fix|bug|patch|repair|correct)'; then
    local_type="fix"
  elif echo "$TITLE" | grep -qiE '(refactor|cleanup|reorganize)'; then
    local_type="refactor"
  elif echo "$TITLE" | grep -qiE '(doc|readme|comment)'; then
    local_type="docs"
  elif echo "$TITLE" | grep -qiE '(test|spec)'; then
    local_type="test"
  fi

  COMMIT_MSG="${local_type}(${SLUG}): ${TITLE}

Forge: ${BEAD_ID}
Risk: ${TIER}"

  git commit -m "$COMMIT_MSG" || {
    echo "{\"error\":\"Commit failed\"}" >&2
    exit 1
  }

  # Push branch
  git push -u origin "$BRANCH" 2>/dev/null || {
    echo "{\"error\":\"Push failed. You may need to set up remote.\"}" >&2
    exit 1
  }

  # Checkpoint
  bash "$BEAD_STATE" checkpoint "$BEAD_ID" "pushed" "{\"branch\":\"${BRANCH}\"}" >/dev/null 2>&1 || true

  # Unlock files
  if [[ -n "$MODIFIED_FILES" ]]; then
    local files_arr=()
    while IFS= read -r f; do
      [[ -n "$f" ]] && files_arr+=("$f")
    done <<< "$MODIFIED_FILES"
    if [[ ${#files_arr[@]} -gt 0 ]]; then
      bash "$BEAD_STATE" unlock-files "$BEAD_ID" "${files_arr[@]}" >/dev/null 2>&1 || true
    fi
  fi

  # PAUSE: ask LLM to write PR body
  PR_BODY_OUTPUT="${FORGE_DIR}/beads/active/${BEAD_ID}/pr-body.md"

  jq -n \
    --arg status "PAUSE" \
    --arg task "write-pr-body" \
    --arg prompt_file "${PROMPTS_DIR}/pr-body-prompt.md" \
    --arg output_file "$PR_BODY_OUTPUT" \
    --arg branch "$BRANCH" \
    --arg resume "bash ${FORGE_DIR}/pipeline/deliver.sh ${BEAD_ID} ${PR_BODY_OUTPUT}" \
    --argjson context '["{{stackFile}}","{{projectFile}}"]' \
    '{status:$status, task:$task, prompt_file:$prompt_file, output_file:$output_file, branch:$branch, context:$context, resume:$resume}'
  exit 0
fi

# --- Phase 2: Create PR with body ---

if [[ ! -f "$PR_BODY_FILE" ]]; then
  echo "{\"error\":\"PR body file not found: ${PR_BODY_FILE}\"}" >&2
  exit 1
fi

PR_BODY=$(cat "$PR_BODY_FILE")

# Determine PR title
PR_TITLE="${TITLE}"
if [[ ${#PR_TITLE} -gt 70 ]]; then
  PR_TITLE=$(echo "$PR_TITLE" | cut -c1-67)"..."
fi

# Add risk badge to PR body
RISK_BADGE=""
case "$TIER" in
  T1) RISK_BADGE="<!-- risk:T1 --> **Risk: T1** (Low — UI/docs/config)" ;;
  T2) RISK_BADGE="<!-- risk:T2 --> **Risk: T2** (Moderate — logic/API/state)" ;;
  T3) RISK_BADGE="<!-- risk:T3 --> **Risk: T3** (Critical — auth/security/PII)" ;;
esac

FULL_BODY="${RISK_BADGE}

${PR_BODY}

---
Forge bead: \`${BEAD_ID}\`"

# Create PR
PR_URL=$(gh pr create \
  --title "$PR_TITLE" \
  --body "$FULL_BODY" \
  --head "$BRANCH" 2>/dev/null) || {
  echo "{\"error\":\"gh pr create failed. Is gh authenticated?\"}" >&2
  exit 1
}

# Add labels based on tier
case "$TIER" in
  T3) gh pr edit "$PR_URL" --add-label "critical,security-review" 2>/dev/null || true ;;
  T2) gh pr edit "$PR_URL" --add-label "needs-review" 2>/dev/null || true ;;
esac

# Checkpoint
bash "$BEAD_STATE" checkpoint "$BEAD_ID" "pr-created" "{\"pr_url\":\"${PR_URL}\"}" >/dev/null 2>&1 || true

jq -n \
  --arg pr_url "$PR_URL" \
  --arg branch "$BRANCH" \
  --arg bead_id "$BEAD_ID" \
  --arg tier "$TIER" \
  '{pr_url:$pr_url, branch:$branch, bead_id:$bead_id, tier:$tier}'
