#!/usr/bin/env bash
# forge pipeline — shared utilities
# Generated by: forge init
# Source this file: source .forge/pipeline/helpers.sh

FORGE_DIR="${FORGE_DIR:-.forge}"
CONFIG_FILE="${FORGE_DIR}/forge.yaml"

# --- bd helpers ---

# Get a field from a bd issue (handles array or object response)
bd_get_field() {
  local task_id="$1" field="$2"
  bd show "$task_id" --json 2>/dev/null | jq -r "if type == \"array\" then .[0].${field} else .${field} end // empty"
}

# Get a label value by prefix (e.g., bd_get_label "beads-xxx" "tier" → "T2")
bd_get_label() {
  local task_id="$1" label_prefix="$2"
  bd show "$task_id" --json 2>/dev/null | jq -r "if type == \"array\" then .[0].labels[]? else .labels[]? end // empty" | grep "^${label_prefix}:" | head -1 | sed "s/^${label_prefix}://" || true
}

# --- Config reading ---

# Read a value from forge.yaml (supports dotted keys like "commands.typecheck")
read_config() {
  local key="$1"
  local file="$CONFIG_FILE"
  if [[ ! -f "$file" ]]; then
    echo ""
    return
  fi
  if [[ "$key" == *.* ]]; then
    local section="${key%%.*}"
    local subkey="${key#*.}"
    sed -n "/^${section}:/,/^[^ ]/p" "$file" | grep "^  ${subkey}:" | head -1 | sed 's/^[^:]*: *//' | sed 's/^ *"//' | sed 's/" *$//'
  else
    grep "^${key}:" "$file" | head -1 | sed 's/^[^:]*: *//' | sed 's/^ *"//' | sed 's/" *$//'
  fi
}

read_config_bool() {
  local val
  val=$(read_config "$1")
  [[ "$val" == "true" || "$val" == "yes" || "$val" == "1" ]]
}

# --- String helpers ---

# Convert a title to a URL-safe slug
slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | \
    sed 's/[^a-z0-9]/-/g' | \
    sed 's/--*/-/g' | \
    sed 's/^-//' | \
    sed 's/-$//' | \
    cut -c1-40
}

# --- Path helpers ---

# Get the run directory for a task
task_dir() {
  local task_id="$1"
  echo "${FORGE_DIR}/pipeline/runs/${task_id}"
}

# Ensure the run directory and reports subdirectory exist
ensure_run_dir() {
  local task_id="$1"
  local dir
  dir=$(task_dir "$task_id")
  mkdir -p "${dir}/reports"
  echo "$dir"
}
