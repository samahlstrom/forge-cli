#!/usr/bin/env bash
# forge pipeline orchestrator — main state machine
# Generated by: forge init
set -euo pipefail

FORGE_DIR=".forge"
PIPELINE_DIR="${FORGE_DIR}/pipeline"
BEADS_DIR="${FORGE_DIR}/beads"
CONFIG_FILE="${FORGE_DIR}/forge.yaml"
BEAD_STATE="${PIPELINE_DIR}/bead-state.sh"
INTAKE="${PIPELINE_DIR}/intake.sh"
CLASSIFY="${PIPELINE_DIR}/classify.sh"
VERIFY="${PIPELINE_DIR}/verify.sh"
DELIVER="${PIPELINE_DIR}/deliver.sh"
PROMPTS_DIR="${PIPELINE_DIR}"

# --- Helpers ---

emit_json() {
  echo "$1"
}

emit_pause() {
  local task="$1" prompt_file="$2" output_file="$3" resume_stage="$4" bead_id="$5"
  shift 5
  local ctx_files=("$@")
  local ctx_json
  ctx_json=$(printf '%s\n' "${ctx_files[@]}" | jq -R . | jq -s .)
  jq -n \
    --arg status "PAUSE" \
    --arg task "$task" \
    --arg prompt_file "$prompt_file" \
    --arg output_file "$output_file" \
    --argjson context "$ctx_json" \
    --arg resume "bash ${PIPELINE_DIR}/orchestrator.sh --resume ${bead_id} --stage ${resume_stage}" \
    '{status:$status, task:$task, prompt_file:$prompt_file, output_file:$output_file, context:$context, resume:$resume}'
}

emit_human_input() {
  local question="$1" bead_id="$2"
  shift 2
  local options=("$@")
  local opts_json
  opts_json=$(printf '%s\n' "${options[@]}" | jq -R . | jq -s .)
  jq -n \
    --arg status "HUMAN_INPUT" \
    --arg question "$question" \
    --argjson options "$opts_json" \
    --arg resume "bash ${PIPELINE_DIR}/orchestrator.sh --resume ${bead_id} --answer \"\${idx}\"" \
    '{status:$status, question:$question, options:$options, resume:$resume}'
}

emit_done() {
  local pr_url="$1" branch="$2" summary="$3"
  jq -n \
    --arg status "DONE" \
    --arg pr_url "$pr_url" \
    --arg branch "$branch" \
    --arg summary "$summary" \
    '{status:$status, pr_url:$pr_url, branch:$branch, summary:$summary}'
}

emit_error() {
  local stage="$1" error="$2" debug_file="${3:-}" action="${4:-}"
  jq -n \
    --arg status "ERROR" \
    --arg stage "$stage" \
    --arg error "$error" \
    --arg debug_file "$debug_file" \
    --arg action "$action" \
    '{status:$status, stage:$stage, error:$error, debug_file:$debug_file, action:$action}'
}

read_config() {
  local key="$1"
  # Simple yaml reader: handles top-level and dotted keys like "commands.typecheck"
  local file="$CONFIG_FILE"
  if [[ ! -f "$file" ]]; then
    echo ""
    return
  fi
  if [[ "$key" == *.* ]]; then
    local section="${key%%.*}"
    local subkey="${key#*.}"
    sed -n "/^${section}:/,/^[^ ]/p" "$file" | grep "^  ${subkey}:" | head -1 | sed 's/^[^:]*: *//' | sed 's/^ *"//' | sed 's/" *$//'
  else
    grep "^${key}:" "$file" | head -1 | sed 's/^[^:]*: *//' | sed 's/^ *"//' | sed 's/" *$//'
  fi
}

get_bead_field() {
  local bead_id="$1" field="$2"
  bash "$BEAD_STATE" get "$bead_id" | jq -r ".${field} // empty"
}

# --- Stage Functions ---

stage_intake() {
  local args=("$@")
  local intake_result
  intake_result=$(bash "$INTAKE" "${args[@]}") || {
    emit_error "intake" "Intake parsing failed" "" "bash ${INTAKE} ${args[*]}"
    exit 1
  }

  local title description source mode quality_score
  title=$(echo "$intake_result" | jq -r '.title')
  description=$(echo "$intake_result" | jq -r '.description')
  source=$(echo "$intake_result" | jq -r '.source')
  mode=$(echo "$intake_result" | jq -r '.mode')
  quality_score=$(echo "$intake_result" | jq -r '.quality_score')

  # Create bead
  local bead_id
  bead_id=$(bash "$BEAD_STATE" create "$title" "$description" "$source" "$mode") || {
    emit_error "intake" "Failed to create bead" "" ""
    exit 1
  }

  # Store intake result in bead dir
  echo "$intake_result" > "${BEADS_DIR}/active/${bead_id}/intake.json"

  echo "$bead_id|$quality_score|$mode"
}

stage_quality_gate() {
  local bead_id="$1" quality_score="$2"
  local threshold
  threshold=$(read_config "quality_threshold")
  threshold="${threshold:-0.4}"

  if (( $(echo "$quality_score < $threshold" | bc -l) )); then
    emit_human_input \
      "Work description scored ${quality_score} (threshold: ${threshold}). The description may be too vague. Would you like to:" \
      "$bead_id" \
      "Continue anyway" \
      "Provide more detail" \
      "Cancel"
    exit 0
  fi
}

stage_classify() {
  local bead_id="$1"
  local description
  description=$(get_bead_field "$bead_id" "description")

  local classify_result
  classify_result=$(bash "$CLASSIFY" "$description") || {
    emit_error "classify" "Classification failed" "" ""
    exit 1
  }

  local tier reason
  tier=$(echo "$classify_result" | jq -r '.tier')
  reason=$(echo "$classify_result" | jq -r '.reason')

  # Update bead with tier
  bash "$BEAD_STATE" checkpoint "$bead_id" "classified" "{\"tier\":\"${tier}\",\"reason\":\"${reason}\"}"

  echo "$tier"
}

stage_decompose_check() {
  local bead_id="$1" tier="$2" mode="$3"
  local decompose_threshold
  decompose_threshold=$(read_config "decompose_threshold")
  decompose_threshold="${decompose_threshold:-T2}"

  # Quick and hotfix modes skip decomposition
  if [[ "$mode" == "quick" || "$mode" == "hotfix" ]]; then
    echo "skip"
    return
  fi

  # T1 tasks skip decomposition unless forced
  if [[ "$tier" == "T1" && "$decompose_threshold" != "T1" ]]; then
    echo "skip"
    return
  fi

  echo "decompose"
}

stage_decompose() {
  local bead_id="$1"
  local output_file="${BEADS_DIR}/active/${bead_id}/decomposition.json"

  bash "$BEAD_STATE" transition "$bead_id" "decomposing"

  emit_pause \
    "decompose" \
    "${PROMPTS_DIR}/decompose.md" \
    "$output_file" \
    "execute" \
    "$bead_id" \
    "{{stackFile}}" "{{projectFile}}"
  exit 0
}

stage_execute() {
  local bead_id="$1"
  local output_file="${BEADS_DIR}/active/${bead_id}/execution.json"

  bash "$BEAD_STATE" transition "$bead_id" "executing"

  emit_pause \
    "execute" \
    "${PROMPTS_DIR}/execute.md" \
    "$output_file" \
    "verify" \
    "$bead_id" \
    "{{stackFile}}" "{{projectFile}}"
  exit 0
}

stage_verify() {
  local bead_id="$1" tier="$2"

  bash "$BEAD_STATE" transition "$bead_id" "verifying"

  local verify_result
  verify_result=$(bash "$VERIFY" "$bead_id" "$tier") || true

  local passed
  passed=$(echo "$verify_result" | jq -r '.passed // false')

  if [[ "$passed" != "true" ]]; then
    local failed_check stderr_output
    failed_check=$(echo "$verify_result" | jq -r '.failed_check // "unknown"')
    stderr_output=$(echo "$verify_result" | jq -r '.stderr // ""')

    local debug_file="${BEADS_DIR}/active/${bead_id}/verify-failure.json"
    echo "$verify_result" > "$debug_file"

    emit_error "verify" "Check failed: ${failed_check}" "$debug_file" \
      "bash ${PIPELINE_DIR}/orchestrator.sh --resume ${bead_id} --stage verify"
    exit 1
  fi

  bash "$BEAD_STATE" checkpoint "$bead_id" "verified" '{"all_checks":"passed"}'
}

stage_deliver() {
  local bead_id="$1"

  bash "$BEAD_STATE" transition "$bead_id" "delivering"

  local deliver_result
  deliver_result=$(bash "$DELIVER" "$bead_id") || {
    emit_error "deliver" "Delivery failed" "" ""
    exit 1
  }

  local pr_url branch
  pr_url=$(echo "$deliver_result" | jq -r '.pr_url // ""')
  branch=$(echo "$deliver_result" | jq -r '.branch // ""')

  if [[ -z "$pr_url" ]]; then
    # Deliver paused for PR body — relay the pause
    echo "$deliver_result"
    exit 0
  fi

  local title
  title=$(get_bead_field "$bead_id" "title")

  bash "$BEAD_STATE" close "$bead_id"
  emit_done "$pr_url" "$branch" "Delivered: ${title}"
}

# --- Main ---

RESUME_ID=""
RESUME_STAGE=""
ANSWER=""
INPUT_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --resume)
      RESUME_ID="$2"; shift 2 ;;
    --stage)
      RESUME_STAGE="$2"; shift 2 ;;
    --answer)
      ANSWER="$2"; shift 2 ;;
    *)
      INPUT_ARGS+=("$1"); shift ;;
  esac
done

# Resume mode
if [[ -n "$RESUME_ID" && -n "$RESUME_STAGE" ]]; then
  bead_id="$RESUME_ID"
  tier=$(get_bead_field "$bead_id" "tier")
  tier="${tier:-T1}"
  mode=$(get_bead_field "$bead_id" "mode")
  mode="${mode:-normal}"

  case "$RESUME_STAGE" in
    execute)    stage_execute "$bead_id" ;;
    verify)     stage_verify "$bead_id" "$tier" ;;
    deliver)    stage_deliver "$bead_id" ;;
    *)          emit_error "resume" "Unknown stage: ${RESUME_STAGE}" "" ""; exit 1 ;;
  esac
  exit 0
fi

# Handle quality gate answer
if [[ -n "$RESUME_ID" && -n "$ANSWER" ]]; then
  bead_id="$RESUME_ID"
  case "$ANSWER" in
    0) ;; # Continue anyway — fall through
    1) emit_error "quality-gate" "User chose to provide more detail" "" ""; exit 0 ;;
    2) bash "$BEAD_STATE" close "$bead_id"; emit_error "quality-gate" "Cancelled by user" "" ""; exit 0 ;;
  esac
  # Resume from classify
  tier=$(stage_classify "$bead_id")
  mode=$(get_bead_field "$bead_id" "mode")
  mode="${mode:-normal}"
  decompose_decision=$(stage_decompose_check "$bead_id" "$tier" "$mode")
  if [[ "$decompose_decision" == "decompose" ]]; then
    stage_decompose "$bead_id"
  fi
  stage_execute "$bead_id"
  exit 0
fi

# Fresh run
if [[ ${#INPUT_ARGS[@]} -eq 0 ]]; then
  emit_error "intake" "No work description provided" "" "forge work \"<description>\""
  exit 1
fi

# Stage: intake
intake_output=$(stage_intake "${INPUT_ARGS[@]}")
bead_id=$(echo "$intake_output" | cut -d'|' -f1)
quality_score=$(echo "$intake_output" | cut -d'|' -f2)
mode=$(echo "$intake_output" | cut -d'|' -f3)

# Stage: quality-gate
stage_quality_gate "$bead_id" "$quality_score"

# Stage: classify
tier=$(stage_classify "$bead_id")

# Stage: decompose-check
decompose_decision=$(stage_decompose_check "$bead_id" "$tier" "$mode")

# Stage: decompose (if needed)
if [[ "$decompose_decision" == "decompose" ]]; then
  stage_decompose "$bead_id"
  # ^ emits PAUSE and exits; orchestrator resumes at --stage execute
fi

# Stage: execute
stage_execute "$bead_id"
# ^ emits PAUSE and exits; orchestrator resumes at --stage verify
