#!/usr/bin/env bash
# forge pipeline orchestrator — main state machine
# Generated by: forge init
# Uses bd (steveyegge/beads) for task tracking
set -euo pipefail

FORGE_DIR=".forge"
PIPELINE_DIR="${FORGE_DIR}/pipeline"
CONFIG_FILE="${FORGE_DIR}/forge.yaml"
INTAKE="${PIPELINE_DIR}/intake.sh"
VERIFY="${PIPELINE_DIR}/verify.sh"
DELIVER="${PIPELINE_DIR}/deliver.sh"
PROMPTS_DIR="${PIPELINE_DIR}"
CLASSIFY_PROMPT="${PROMPTS_DIR}/classify.md"
REVIEW_PLAN="${PROMPTS_DIR}/review-plan.md"

# --- Helpers ---

emit_json() {
  echo "$1"
}

emit_pause() {
  local task="$1" prompt_file="$2" output_file="$3" resume_stage="$4" task_id="$5"
  shift 5
  local ctx_files=("$@")
  local ctx_json
  if [[ ${#ctx_files[@]} -eq 0 ]]; then
    ctx_json='[]'
  else
    ctx_json=$(printf '%s\n' "${ctx_files[@]}" | jq -R . | jq -s .)
  fi
  jq -n \
    --arg status "PAUSE" \
    --arg task "$task" \
    --arg prompt_file "$prompt_file" \
    --arg output_file "$output_file" \
    --argjson context "$ctx_json" \
    --arg resume "bash ${PIPELINE_DIR}/orchestrator.sh --resume ${task_id} --stage ${resume_stage}" \
    '{status:$status, task:$task, prompt_file:$prompt_file, output_file:$output_file, context:$context, resume:$resume}'
}

emit_done() {
  local pr_url="$1" branch="$2" summary="$3"
  jq -n \
    --arg status "DONE" \
    --arg pr_url "$pr_url" \
    --arg branch "$branch" \
    --arg summary "$summary" \
    '{status:$status, pr_url:$pr_url, branch:$branch, summary:$summary}'
}

emit_error() {
  local stage="$1" error="$2" debug_file="${3:-}" action="${4:-}"
  jq -n \
    --arg status "ERROR" \
    --arg stage "$stage" \
    --arg error "$error" \
    --arg debug_file "$debug_file" \
    --arg action "$action" \
    '{status:$status, stage:$stage, error:$error, debug_file:$debug_file, action:$action}'
}

read_config() {
  local key="$1"
  local file="$CONFIG_FILE"
  if [[ ! -f "$file" ]]; then
    echo ""
    return
  fi
  if [[ "$key" == *.* ]]; then
    local section="${key%%.*}"
    local subkey="${key#*.}"
    sed -n "/^${section}:/,/^[^ ]/p" "$file" | grep "^  ${subkey}:" | head -1 | sed 's/^[^:]*: *//' | sed 's/^ *"//' | sed 's/" *$//'
  else
    grep "^${key}:" "$file" | head -1 | sed 's/^[^:]*: *//' | sed 's/^ *"//' | sed 's/" *$//'
  fi
}

# --- bd helpers ---

bd_get_field() {
  local task_id="$1" field="$2"
  bd show "$task_id" --json 2>/dev/null | jq -r "if type == \"array\" then .[0].${field} else .${field} end // empty"
}

bd_get_label() {
  local task_id="$1" label_prefix="$2"
  bd show "$task_id" --json 2>/dev/null | jq -r "if type == \"array\" then .[0].labels[]? else .labels[]? end // empty" | grep "^${label_prefix}:" | head -1 | sed "s/^${label_prefix}://" || true
}

# --- Stage Functions ---

stage_intake() {
  local args=("$@")
  local intake_result
  intake_result=$(bash "$INTAKE" "${args[@]}") || {
    emit_error "intake" "Intake parsing failed" "" "bash ${INTAKE} ${args[*]}"
    exit 1
  }

  local title description source mode quality_score
  title=$(echo "$intake_result" | jq -r '.title')
  description=$(echo "$intake_result" | jq -r '.description')
  source=$(echo "$intake_result" | jq -r '.source')
  mode=$(echo "$intake_result" | jq -r '.mode')
  quality_score=$(echo "$intake_result" | jq -r '.quality_score')

  # Create task in bd
  local task_id
  task_id=$(echo "$description" | bd create "$title" --body-file - -l "mode:${mode},source:${source}" --json 2>/dev/null | jq -r '.id') || {
    emit_error "intake" "Failed to create task in bd" "" ""
    exit 1
  }

  # Store intake result alongside the task
  local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
  mkdir -p "$task_dir"
  echo "$intake_result" > "${task_dir}/intake.json"

  echo "$task_id|$quality_score|$mode"
}

# Classification is now an LLM agent — no keyword matching.
# The orchestrator PAUSEs for an LLM to read the bead and assign a tier.
stage_classify() {
  local task_id="$1"
  local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
  local output_file="${task_dir}/classification.json"
  mkdir -p "$task_dir"

  emit_pause \
    "classify" \
    "$CLASSIFY_PROMPT" \
    "$output_file" \
    "post-classify" \
    "$task_id"
  exit 0
}

# Reads the classification result and labels the bead
stage_post_classify() {
  local task_id="$1"
  local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
  local class_file="${task_dir}/classification.json"

  if [[ ! -f "$class_file" ]]; then
    emit_error "classify" "No classification file found at ${class_file}" "" ""
    exit 1
  fi

  local tier
  tier=$(jq -r '.tier // "T2"' "$class_file")

  # Validate tier value
  case "$tier" in
    T1|T2|T3) ;;
    *) tier="T2" ;; # Default to moderate if agent returned garbage
  esac

  # Label the bead
  bd update "$task_id" -l "tier:${tier}" 2>/dev/null

  echo "$tier"
}

stage_decompose_check() {
  local task_id="$1" tier="$2" mode="$3"

  # Quick and hotfix modes are the ONLY way to skip decomposition.
  # Every normal task goes through architect decomposition and plan review,
  # regardless of tier. The LLM should never decide to skip this.
  if [[ "$mode" == "quick" || "$mode" == "hotfix" ]]; then
    echo "skip"
    return
  fi

  echo "decompose"
}

stage_decompose() {
  local task_id="$1"
  local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
  local output_file="${task_dir}/decomposition.json"
  mkdir -p "$task_dir"

  # Claim the task
  bd update "$task_id" --claim 2>/dev/null

  emit_pause \
    "decompose" \
    "${PROMPTS_DIR}/decompose.md" \
    "$output_file" \
    "review-plan" \
    "$task_id" \
    "{{stackFile}}" "{{projectFile}}"
  exit 0
}

stage_review_plan() {
  local task_id="$1"
  local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
  local output_file="${task_dir}/plan-review.json"
  mkdir -p "$task_dir"

  emit_pause \
    "review-plan" \
    "${PROMPTS_DIR}/review-plan.md" \
    "$output_file" \
    "review-plan-check" \
    "$task_id" \
    "{{stackFile}}" "{{projectFile}}"
  exit 0
}

# Auto-handle plan review verdicts — no human escalation for revise/reject.
# If the plan is bad, loop back to the architect silently.
# Only hard-fail after max review cycles.
stage_review_plan_check() {
  local task_id="$1"
  local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
  local review_file="${task_dir}/plan-review.json"

  if [[ ! -f "$review_file" ]]; then
    emit_error "review-plan" "No plan review file found" "" ""
    exit 1
  fi

  local verdict
  verdict=$(jq -r '.verdict // "reject"' "$review_file")

  # Count review cycles
  local review_count=1
  while [[ -f "${task_dir}/plan-review-${review_count}.json" ]]; do
    review_count=$((review_count + 1))
  done

  case "$verdict" in
    approve)
      echo "execute"
      ;;
    revise)
      # Auto-loop: archive current review, re-run decompose
      if [[ $review_count -ge 3 ]]; then
        # 3 review cycles exhausted — this is a real failure
        emit_error "review-plan" \
          "Plan failed review ${review_count} times. Architect cannot produce an acceptable plan for this task." \
          "$review_file" \
          "bash ${PIPELINE_DIR}/orchestrator.sh --resume ${task_id} --stage decompose"
        exit 1
      fi
      mv "$review_file" "${task_dir}/plan-review-${review_count}.json"
      echo "re-decompose"
      ;;
    reject)
      # Same as revise — try again, don't ask human
      if [[ $review_count -ge 3 ]]; then
        emit_error "review-plan" \
          "Plan rejected ${review_count} times. Task description may be too ambiguous for automated decomposition." \
          "$review_file" \
          "bash ${PIPELINE_DIR}/orchestrator.sh --resume ${task_id} --stage decompose"
        exit 1
      fi
      mv "$review_file" "${task_dir}/plan-review-${review_count}.json"
      echo "re-decompose"
      ;;
    *)
      emit_error "review-plan" "Unknown verdict: ${verdict}" "$review_file" ""
      exit 1
      ;;
  esac
}

stage_execute() {
  local task_id="$1"
  local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
  local reports_dir="${task_dir}/reports"
  local output_file="${task_dir}/execution.json"
  local decomp_file="${task_dir}/decomposition.json"
  mkdir -p "$reports_dir"

  # Ensure task is claimed/in-progress
  bd update "$task_id" --claim 2>/dev/null

  if [[ ! -f "$decomp_file" ]]; then
    emit_error "execute" "No decomposition file found at ${decomp_file}" "" \
      "bash ${PIPELINE_DIR}/orchestrator.sh --resume ${task_id} --stage decompose"
    exit 1
  fi

  local title
  title=$(bd_get_field "$task_id" "title")

  # --- Read the decomposition plan ---
  local wave_count subtask_count
  wave_count=$(jq '.waves | length' "$decomp_file")
  subtask_count=$(jq '.subtasks | length' "$decomp_file")

  # --- Gather revision context if this is a re-execution ---
  local revision_context=""
  local latest_eval="${task_dir}/evaluation-1.json"
  local eval_idx=1
  while [[ -f "${task_dir}/evaluation-${eval_idx}.json" ]]; do
    latest_eval="${task_dir}/evaluation-${eval_idx}.json"
    eval_idx=$((eval_idx + 1))
  done
  if [[ -f "$latest_eval" ]]; then
    revision_context="REVISION MODE: Previous evaluation found issues. Read ${latest_eval} for details. Focus on critical/high findings. Do NOT re-implement things that already passed."
  fi

  # --- Execute wave by wave ---
  local waves_executed=0
  local all_completed=()
  local all_deferred=()
  local all_files_modified=()
  local agent_reports="[]"

  for (( w=1; w<=wave_count; w++ )); do
    # Get subtask IDs for this wave
    local wave_subtask_ids
    wave_subtask_ids=$(jq -r ".waves[$((w-1))].subtasks[]" "$decomp_file")

    local pids=()
    local subtask_ids=()

    # Launch all subtasks in this wave in parallel
    while IFS= read -r st_id; do
      [[ -z "$st_id" ]] && continue

      local st_title st_agent st_instructions st_verification st_files
      st_title=$(jq -r ".subtasks[] | select(.id == \"${st_id}\") | .title" "$decomp_file")
      st_agent=$(jq -r ".subtasks[] | select(.id == \"${st_id}\") | .agent" "$decomp_file")
      st_instructions=$(jq -r ".subtasks[] | select(.id == \"${st_id}\") | .instructions" "$decomp_file")
      st_verification=$(jq -r ".subtasks[] | select(.id == \"${st_id}\") | .verification" "$decomp_file")
      st_files=$(jq -r ".subtasks[] | select(.id == \"${st_id}\") | .files[]" "$decomp_file" | tr '\n' ', ' | sed 's/,$//')

      local agent_file=".forge/agents/${st_agent}.md"
      local agent_instructions=""
      if [[ -f "$agent_file" ]]; then
        agent_instructions="Read and follow your agent instructions at ${agent_file} — especially the Agent Contract."
      fi

      local report_file="${reports_dir}/${st_id}.json"

      # Build the prompt for this subtask agent
      local agent_prompt="You are a ${st_agent} agent. ${agent_instructions}

Task: ${title}
Subtask: ${st_title} (${st_id})

Instructions:
${st_instructions}

Files to modify: ${st_files}
Only modify these files. Do not touch other files.

Verification: ${st_verification}

Project context files: {{stackFile}}, {{projectFile}} — read them for conventions.

${revision_context}

After completing your work, write your structured JSON report to: ${report_file}
The report must follow the format in your agent .md file.
If you encounter an error you cannot resolve, write your report with status: blocked."

      claude --print -p "$agent_prompt" > "${reports_dir}/${st_id}-stdout.log" 2>&1 &
      pids+=($!)
      subtask_ids+=("$st_id")

    done <<< "$wave_subtask_ids"

    # Wait for all subtasks in this wave
    local wave_failures=()
    for i in "${!pids[@]}"; do
      local exit_code=0
      wait "${pids[$i]}" || exit_code=$?
      local st_id="${subtask_ids[$i]}"
      local report_file="${reports_dir}/${st_id}.json"

      if [[ $exit_code -ne 0 ]] || [[ ! -f "$report_file" ]]; then
        # Agent failed or didn't produce a report — retry once
        local st_agent st_title
        st_agent=$(jq -r ".subtasks[] | select(.id == \"${st_id}\") | .agent" "$decomp_file")
        st_title=$(jq -r ".subtasks[] | select(.id == \"${st_id}\") | .title" "$decomp_file")

        local retry_context="RETRY: Your previous attempt failed (exit code: ${exit_code}). "
        if [[ -f "${reports_dir}/${st_id}-stdout.log" ]]; then
          retry_context+="Previous output: $(tail -50 "${reports_dir}/${st_id}-stdout.log")"
        fi

        local retry_exit=0
        claude --print -p "${retry_context} Try again. Write your JSON report to ${report_file}." \
          > "${reports_dir}/${st_id}-retry-stdout.log" 2>&1 || retry_exit=$?

        if [[ $retry_exit -ne 0 ]] || [[ ! -f "$report_file" ]]; then
          wave_failures+=("$st_id")
          # Write a failure report
          jq -n --arg id "$st_id" --arg agent "$st_agent" \
            '{subtask_id:$id, agent:$agent, status:"failed", what_i_did:"Agent failed after retry", files_modified:[], decisions:[], issues_encountered:["Agent process failed"]}' \
            > "$report_file"
        fi
      fi

      # Collect into agent reports
      if [[ -f "$report_file" ]]; then
        agent_reports=$(echo "$agent_reports" | jq --slurpfile r "$report_file" '. + $r')
        local status
        status=$(jq -r '.status // "unknown"' "$report_file" 2>/dev/null)
        if [[ "$status" == "complete" ]]; then
          all_completed+=("$st_id")
        else
          all_deferred+=("$st_id")
        fi
        # Collect modified files
        local modified
        modified=$(jq -r '.files_modified[]? // empty' "$report_file" 2>/dev/null)
        while IFS= read -r f; do
          [[ -n "$f" ]] && all_files_modified+=("$f")
        done <<< "$modified"
      fi
    done

    waves_executed=$w

    # --- Post-wave verification gate ---
    local typecheck_exit=0
    eval "{{commands.typecheck}}" >/dev/null 2>&1 || typecheck_exit=$?

    if [[ $typecheck_exit -ne 0 ]]; then
      # Typecheck failed after this wave — revert failed subtasks' files
      for fail_id in "${wave_failures[@]}"; do
        local fail_files
        fail_files=$(jq -r ".subtasks[] | select(.id == \"${fail_id}\") | .files[]" "$decomp_file")
        while IFS= read -r f; do
          [[ -n "$f" ]] && git checkout -- "$f" 2>/dev/null || true
        done <<< "$fail_files"
      done
    fi

    # Check if wave gate requires tests too
    local wave_gate
    wave_gate=$(jq -r ".waves[$((w-1))].gate // \"typecheck\"" "$decomp_file")
    if [[ "$wave_gate" == *"test"* ]]; then
      eval "{{commands.test}}" >/dev/null 2>&1 || true
    fi
  done

  # --- Final verification ---
  local tc_pass="failed" lint_pass="failed" test_pass="failed"
  eval "{{commands.typecheck}}" >/dev/null 2>&1 && tc_pass="passed"
  eval "{{commands.lint}}" >/dev/null 2>&1 && lint_pass="passed"
  eval "{{commands.test}}" >/dev/null 2>&1 && test_pass="passed"

  # --- Deduplicate files ---
  local unique_files
  unique_files=$(printf '%s\n' "${all_files_modified[@]}" | sort -u | jq -R . | jq -s .)

  # --- Write execution.json ---
  local completed_json deferred_json
  completed_json=$(printf '%s\n' "${all_completed[@]}" | jq -R . | jq -s '.')
  deferred_json=$(printf '%s\n' "${all_deferred[@]}" | jq -R . | jq -s '.')

  jq -n \
    --arg status "complete" \
    --argjson waves "$waves_executed" \
    --argjson completed "$completed_json" \
    --argjson deferred "$deferred_json" \
    --argjson files "$unique_files" \
    --arg typecheck "$tc_pass" \
    --arg lint "$lint_pass" \
    --arg test "$test_pass" \
    '{
      status: $status,
      waves_executed: $waves,
      subtasks_completed: $completed,
      subtasks_deferred: $deferred,
      files_modified: $files,
      verification: { typecheck: $typecheck, lint: $lint, test: $test }
    }' > "$output_file"

  # --- Write agent-log.json ---
  jq -n \
    --arg dispatcher "execute" \
    --arg task_id "$task_id" \
    --arg status "complete" \
    --argjson waves "$waves_executed" \
    --argjson agent_reports "$agent_reports" \
    '{
      dispatcher: $dispatcher,
      task_id: $task_id,
      status: $status,
      waves_executed: $waves,
      agent_reports: $agent_reports
    }' > "${task_dir}/agent-log.json"
}

stage_evaluate() {
  local task_id="$1" tier="$2"
  local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
  local reports_dir="${task_dir}/reports"
  mkdir -p "$reports_dir"

  # Max evaluation iterations — capped at 3 for all tiers.
  local max_iterations=3

  # Find current iteration number
  local iteration=1
  while [[ -f "${task_dir}/evaluation-${iteration}.json" ]]; do
    iteration=$((iteration + 1))
  done

  if [[ $iteration -gt $max_iterations ]]; then
    emit_error "evaluate" "Max evaluation iterations (${max_iterations}) reached. Task cannot pass quality gates." \
      "${task_dir}/evaluation-$((iteration - 1)).json" ""
    exit 1
  fi

  # --- Gather inputs for evaluators ---
  local diff_file="${task_dir}/eval-${iteration}-diff.patch"
  git diff HEAD~1 > "$diff_file" 2>/dev/null || git diff > "$diff_file" 2>/dev/null || true

  local execution_file="${task_dir}/execution.json"
  local title
  title=$(bd_get_field "$task_id" "title")

  # --- Launch three evaluator agents in parallel (mechanical, no LLM dispatch) ---
  local edgar_report="${reports_dir}/eval-${iteration}-edgar.json"
  local cq_report="${reports_dir}/eval-${iteration}-code-quality.json"
  local ua_report="${reports_dir}/eval-${iteration}-um-actually.json"

  local edgar_pid cq_pid ua_pid

  claude --print -p "You are Edgar. Read and follow .forge/agents/edgar.md exactly. \
Evaluate this diff: $(cat "$diff_file"). \
Task: ${title} (${task_id}). Tier: ${tier}. \
Execution summary: $(cat "$execution_file" 2>/dev/null || echo 'not available'). \
Context files: {{stackFile}}, {{projectFile}} — read them. \
Output ONLY your JSON report (no markdown fences, no commentary). Follow the Output Format in edgar.md." \
    > "$edgar_report" 2>/dev/null &
  edgar_pid=$!

  claude --print -p "You are the Code Quality evaluator. Read and follow .forge/agents/code-quality.md exactly. \
Evaluate this diff: $(cat "$diff_file"). \
Task: ${title} (${task_id}). Tier: ${tier}. \
Execution summary: $(cat "$execution_file" 2>/dev/null || echo 'not available'). \
Context files: {{stackFile}}, {{projectFile}} — read them. \
Output ONLY your JSON report (no markdown fences, no commentary). Follow the Output Format in code-quality.md." \
    > "$cq_report" 2>/dev/null &
  cq_pid=$!

  claude --print -p "You are Um-Actually. Read and follow .forge/agents/um-actually.md exactly. \
Evaluate this diff: $(cat "$diff_file"). \
Task: ${title} (${task_id}). Tier: ${tier}. \
Execution summary: $(cat "$execution_file" 2>/dev/null || echo 'not available'). \
Context files: {{stackFile}}, {{projectFile}} — read them. \
Output ONLY your JSON report (no markdown fences, no commentary). Follow the Output Format in um-actually.md." \
    > "$ua_report" 2>/dev/null &
  ua_pid=$!

  # Wait for all three
  local edgar_exit=0 cq_exit=0 ua_exit=0
  wait $edgar_pid || edgar_exit=$?
  wait $cq_pid || cq_exit=$?
  wait $ua_pid || ua_exit=$?

  # --- Extract scores (penalty 0.5 if agent failed or produced invalid JSON) ---
  local edgar_score cq_score ua_score edgar_verdict cq_verdict ua_verdict

  edgar_score=$(jq -r '.scores.weighted_total // 0.5' "$edgar_report" 2>/dev/null || echo "0.5")
  cq_score=$(jq -r '.scores.weighted_total // 0.5' "$cq_report" 2>/dev/null || echo "0.5")
  ua_score=$(jq -r '.scores.weighted_total // 0.5' "$ua_report" 2>/dev/null || echo "0.5")

  edgar_verdict=$(jq -r '.verdict // "conditional"' "$edgar_report" 2>/dev/null || echo "conditional")
  cq_verdict=$(jq -r '.verdict // "conditional"' "$cq_report" 2>/dev/null || echo "conditional")
  ua_verdict=$(jq -r '.verdict // "conditional"' "$ua_report" 2>/dev/null || echo "conditional")

  # --- Aggregate scores ---
  local composite
  composite=$(echo "$edgar_score $cq_score $ua_score" | awk '{printf "%.4f", ($1 * 0.35) + ($2 * 0.35) + ($3 * 0.30)}')

  # --- Determine verdict ---
  local verdict="pass"
  local any_fail=false
  [[ "$edgar_verdict" == "fail" || "$cq_verdict" == "fail" || "$ua_verdict" == "fail" ]] && any_fail=true

  if [[ "$any_fail" == "true" && $iteration -ge $max_iterations ]]; then
    verdict="fail"
  elif (( $(echo "$composite < 0.5" | bc -l) )); then
    if [[ $iteration -ge $max_iterations ]]; then
      verdict="fail"
    else
      verdict="revise"
    fi
  elif (( $(echo "$composite < 0.7" | bc -l) )) || [[ "$any_fail" == "true" ]]; then
    verdict="revise"
  fi

  # --- Build revision brief if needed ---
  local revision_brief="null"
  if [[ "$verdict" == "revise" ]]; then
    local critical_findings
    critical_findings=$(jq -s '[.[] | .findings[]? | select(.severity == "critical" or .severity == "high")] | length' \
      "$edgar_report" "$cq_report" "$ua_report" 2>/dev/null || echo "0")

    revision_brief=$(jq -n \
      --arg edgar_score "$edgar_score" \
      --arg cq_score "$cq_score" \
      --arg ua_score "$ua_score" \
      --arg composite "$composite" \
      --arg iteration "$iteration" \
      --arg max "$max_iterations" \
      --argjson edgar_findings "$(jq '[.findings[]? | select(.severity == "critical" or .severity == "high")]' "$edgar_report" 2>/dev/null || echo '[]')" \
      --argjson cq_findings "$(jq '[.findings[]? | select(.severity == "critical" or .severity == "high")]' "$cq_report" 2>/dev/null || echo '[]')" \
      --argjson ua_findings "$(jq '[.findings[]? | select(.severity == "critical" or .severity == "high")]' "$ua_report" 2>/dev/null || echo '[]')" \
      '{
        iteration: ($iteration | tonumber),
        max_iterations: ($max | tonumber),
        scores: { edgar: ($edgar_score | tonumber), code_quality: ($cq_score | tonumber), um_actually: ($ua_score | tonumber), composite: ($composite | tonumber) },
        critical_findings: ($edgar_findings + $cq_findings + $ua_findings)
      }' | jq -Rs .)
  fi

  # --- Count findings ---
  local critical_count high_count
  critical_count=$(jq -s '[.[] | .findings[]? | select(.severity == "critical")] | length' \
    "$edgar_report" "$cq_report" "$ua_report" 2>/dev/null || echo "0")
  high_count=$(jq -s '[.[] | .findings[]? | select(.severity == "high")] | length' \
    "$edgar_report" "$cq_report" "$ua_report" 2>/dev/null || echo "0")

  # --- Write evaluation output ---
  local output_file="${task_dir}/evaluation-${iteration}.json"
  jq -n \
    --arg task_id "$task_id" \
    --argjson iteration "$iteration" \
    --argjson edgar "$(cat "$edgar_report" 2>/dev/null || echo '{"scores":{},"findings":[],"verdict":"conditional"}')" \
    --argjson code_quality "$(cat "$cq_report" 2>/dev/null || echo '{"scores":{},"findings":[],"verdict":"conditional"}')" \
    --argjson um_actually "$(cat "$ua_report" 2>/dev/null || echo '{"scores":{},"findings":[],"verdict":"conditional"}')" \
    --arg composite "$composite" \
    --arg verdict "$verdict" \
    --argjson revision_brief "$revision_brief" \
    --argjson critical "$critical_count" \
    --argjson high "$high_count" \
    '{
      task_id: $task_id,
      iteration: $iteration,
      evaluators: {
        edgar: ($edgar | {scores, findings, verdict, reported: true}),
        code_quality: ($code_quality | {scores, findings, verdict, reported: true}),
        um_actually: ($um_actually | {scores, findings, verdict, reported: true})
      },
      composite_score: ($composite | tonumber),
      verdict: $verdict,
      revision_brief: $revision_brief,
      critical_findings_count: $critical,
      high_findings_count: $high
    }' > "$output_file"

  # --- Return verdict (no PAUSE, fully mechanical) ---
  echo "$verdict"
}

stage_verify() {
  local task_id="$1" tier="$2"

  local verify_result
  verify_result=$(bash "$VERIFY" "$task_id" "$tier") || true

  local passed
  passed=$(echo "$verify_result" | jq -r '.passed // false')

  if [[ "$passed" != "true" ]]; then
    local failed_check
    failed_check=$(echo "$verify_result" | jq -r '.failed_check // "unknown"')

    local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
    local debug_file="${task_dir}/verify-failure.json"
    mkdir -p "$task_dir"
    echo "$verify_result" > "$debug_file"

    # Verification failure is a real error — pipeline stops here.
    # The execution dispatcher should retry or the user needs to intervene.
    emit_error "verify" "Check failed: ${failed_check}" "$debug_file" \
      "bash ${PIPELINE_DIR}/orchestrator.sh --resume ${task_id} --stage verify"
    exit 1
  fi

  # Mechanical checks passed — now run tri-agent evaluation (fully mechanical, no PAUSE)
  local eval_verdict
  eval_verdict=$(stage_evaluate "$task_id" "$tier")

  case "$eval_verdict" in
    pass)
      stage_deliver "$task_id"
      ;;
    revise)
      # Loop back to execute for revision
      stage_execute "$task_id"
      ;;
    fail)
      local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
      local latest=1
      while [[ -f "${task_dir}/evaluation-$((latest + 1)).json" ]]; do
        latest=$((latest + 1))
      done
      emit_error "evaluate" "Evaluation failed after ${latest} iterations" \
        "${task_dir}/evaluation-${latest}.json" \
        "bash ${PIPELINE_DIR}/orchestrator.sh --resume ${task_id} --stage execute"
      exit 1
      ;;
  esac
}

stage_deliver() {
  local task_id="$1"

  local deliver_result
  deliver_result=$(bash "$DELIVER" "$task_id") || {
    emit_error "deliver" "Delivery failed" "" ""
    exit 1
  }

  local pr_url branch
  pr_url=$(echo "$deliver_result" | jq -r '.pr_url // ""')
  branch=$(echo "$deliver_result" | jq -r '.branch // ""')

  if [[ -z "$pr_url" ]]; then
    echo "$deliver_result"
    exit 0
  fi

  local title
  title=$(bd_get_field "$task_id" "title")

  # Generate run report from collected agent logs
  local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
  local run_report="${task_dir}/run-report.json"
  local agent_log="${task_dir}/agent-log.json"
  local reports_dir="${task_dir}/reports"

  # Collect all agent reports into the run report
  local agent_reports="[]"
  if [[ -d "$reports_dir" ]]; then
    agent_reports=$(find "$reports_dir" -name "*.json" -exec cat {} \; | jq -s '.')
  fi

  # Collect all evaluation results
  local eval_results="[]"
  local eval_idx=1
  while [[ -f "${task_dir}/evaluation-${eval_idx}.json" ]]; do
    eval_results=$(echo "$eval_results" | jq --slurpfile e "${task_dir}/evaluation-${eval_idx}.json" '. + $e')
    eval_idx=$((eval_idx + 1))
  done

  # Build the run report
  jq -n \
    --arg task_id "$task_id" \
    --arg title "$title" \
    --arg pr_url "$pr_url" \
    --arg branch "$branch" \
    --arg tier "$(bd_get_label "$task_id" "tier")" \
    --argjson agent_reports "$agent_reports" \
    --argjson evaluations "$eval_results" \
    --argjson agent_log "$(cat "$agent_log" 2>/dev/null || echo '{}')" \
    '{
      task_id: $task_id,
      title: $title,
      pr_url: $pr_url,
      branch: $branch,
      tier: $tier,
      agent_reports: $agent_reports,
      evaluations: $evaluations,
      agent_log: $agent_log
    }' > "$run_report"

  # Close the task in bd
  bd close "$task_id" --reason "Delivered: PR ${pr_url}" 2>/dev/null
  emit_done "$pr_url" "$branch" "Delivered: ${title}"
}

# --- Main ---

RESUME_ID=""
RESUME_STAGE=""
INPUT_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --resume)
      RESUME_ID="$2"; shift 2 ;;
    --stage)
      RESUME_STAGE="$2"; shift 2 ;;
    *)
      INPUT_ARGS+=("$1"); shift ;;
  esac
done

# Resume mode
if [[ -n "$RESUME_ID" && -n "$RESUME_STAGE" ]]; then
  task_id="$RESUME_ID"
  tier=$(bd_get_label "$task_id" "tier")
  tier="${tier:-T2}"
  mode=$(bd_get_label "$task_id" "mode")
  mode="${mode:-normal}"

  case "$RESUME_STAGE" in
    post-classify)
      tier=$(stage_post_classify "$task_id")
      decompose_decision=$(stage_decompose_check "$task_id" "$tier" "$mode")
      if [[ "$decompose_decision" == "decompose" ]]; then
        stage_decompose "$task_id"
      fi
      stage_execute "$task_id"
      stage_verify "$task_id" "$tier"
      ;;
    decompose)
      stage_decompose "$task_id"
      ;;
    review-plan)
      stage_review_plan "$task_id"
      ;;
    review-plan-check)
      decision=$(stage_review_plan_check "$task_id")
      case "$decision" in
        execute)
          stage_execute "$task_id"
          stage_verify "$task_id" "$tier"
          ;;
        re-decompose)
          stage_decompose "$task_id"
          ;;
      esac
      ;;
    execute)
      # Execute is mechanical — spawns specialized agents per decomposition plan
      stage_execute "$task_id"
      # Falls through to verify → evaluate → deliver (all mechanical)
      stage_verify "$task_id" "$tier"
      ;;
    verify)
      stage_verify "$task_id" "$tier"
      ;;
    evaluate)
      # Evaluate is fully mechanical — runs 3 agents in parallel, aggregates, returns verdict
      eval_verdict=$(stage_evaluate "$task_id" "$tier")
      case "$eval_verdict" in
        pass) stage_deliver "$task_id" ;;
        revise) stage_execute "$task_id" ;;
        fail)
          local task_dir="${FORGE_DIR}/pipeline/runs/${task_id}"
          emit_error "evaluate" "Evaluation failed" "${task_dir}/" \
            "bash ${PIPELINE_DIR}/orchestrator.sh --resume ${task_id} --stage execute"
          exit 1
          ;;
      esac
      ;;
    deliver)
      stage_deliver "$task_id"
      ;;
    *)
      emit_error "resume" "Unknown stage: ${RESUME_STAGE}" "" ""
      exit 1
      ;;
  esac
  exit 0
fi

# Fresh run
if [[ ${#INPUT_ARGS[@]} -eq 0 ]]; then
  emit_error "intake" "No work description provided" "" "forge work \"<description>\""
  exit 1
fi

# Stage: intake (parse input, score quality, create bead)
intake_output=$(stage_intake "${INPUT_ARGS[@]}")
task_id=$(echo "$intake_output" | cut -d'|' -f1)
quality_score=$(echo "$intake_output" | cut -d'|' -f2)
mode=$(echo "$intake_output" | cut -d'|' -f3)

# Quality score is stored in intake.json for reference but no longer gates the pipeline.
# The architect and evaluators handle ambiguity — not a keyword-based quality threshold.

# Stage: classify (LLM agent assigns risk tier)
stage_classify "$task_id"
