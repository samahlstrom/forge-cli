#!/usr/bin/env bash
# forge pipeline — bead-state: bead lifecycle manager
# Generated by: forge init
set -euo pipefail

FORGE_DIR=".forge"
ACTIVE_DIR="${FORGE_DIR}/beads/active"
ARCHIVE_DIR="${FORGE_DIR}/beads/archive"

mkdir -p "$ACTIVE_DIR" "$ARCHIVE_DIR"

# --- Helpers ---

generate_id() {
  local hex
  hex=$(openssl rand -hex 2 2>/dev/null || head -c4 /dev/urandom | xxd -p)
  echo "forge-${hex}"
}

now_iso() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

bead_dir() {
  local id="$1"
  echo "${ACTIVE_DIR}/${id}"
}

bead_file() {
  local id="$1"
  echo "$(bead_dir "$id")/bead.json"
}

require_bead() {
  local id="$1"
  local bf
  bf=$(bead_file "$id")
  if [[ ! -f "$bf" ]]; then
    echo "{\"error\":\"Bead not found: ${id}\"}" >&2
    exit 1
  fi
}

# --- Commands ---

cmd_create() {
  local title="Untitled"
  local description=""
  local source="text"
  local mode="normal"
  local tier=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)       title="$2"; shift 2 ;;
      --description) description="$2"; shift 2 ;;
      --source)      source="$2"; shift 2 ;;
      --mode)        mode="$2"; shift 2 ;;
      --tier)        tier="$2"; shift 2 ;;
      *)
        # Treat bare arg as title if title is still default
        if [[ "$title" == "Untitled" ]]; then
          title="$1"
        fi
        shift ;;
    esac
  done

  local id
  id=$(generate_id)
  local dir
  dir=$(bead_dir "$id")
  mkdir -p "$dir"

  local now
  now=$(now_iso)

  local tier_arg="null"
  if [[ -n "$tier" ]]; then
    tier_arg="\"$tier\""
  fi

  jq -n \
    --arg id "$id" \
    --arg title "$title" \
    --arg description "$description" \
    --arg source "$source" \
    --arg mode "$mode" \
    --arg status "intake" \
    --arg created_at "$now" \
    --arg updated_at "$now" \
    --argjson tier "$tier_arg" \
    '{
      id: $id,
      title: $title,
      description: $description,
      source: $source,
      mode: $mode,
      status: $status,
      riskTier: $tier,
      created_at: $created_at,
      updated_at: $updated_at,
      files: { locked: [], modified: [] },
      checkpoints: [],
      edit_count: 0,
      metadata: {}
    }' > "$(bead_file "$id")"

  echo "$id"
}

cmd_transition() {
  local id="$1"
  local new_status="$2"
  require_bead "$id"

  local bf
  bf=$(bead_file "$id")
  local now
  now=$(now_iso)

  local tmp
  tmp=$(mktemp)
  jq \
    --arg status "$new_status" \
    --arg updated_at "$now" \
    '.status = $status | .updated_at = $updated_at' \
    "$bf" > "$tmp" && mv "$tmp" "$bf"

  echo "{\"id\":\"${id}\",\"status\":\"${new_status}\"}"
}

cmd_lock_files() {
  local id="$1"
  shift
  local files=("$@")
  require_bead "$id"

  local bf
  bf=$(bead_file "$id")
  local now
  now=$(now_iso)

  # Check for conflicts first
  for file in "${files[@]}"; do
    local conflict
    conflict=$(cmd_check_file "$file" "$id")
    local state
    state=$(echo "$conflict" | jq -r '.state')
    if [[ "$state" == "locked_by_other" ]]; then
      local owner
      owner=$(echo "$conflict" | jq -r '.owner')
      echo "{\"error\":\"File ${file} is locked by bead ${owner}\"}" >&2
      exit 1
    fi
  done

  # Build JSON array of files to add
  local files_json
  files_json=$(printf '%s\n' "${files[@]}" | jq -R . | jq -s .)

  local tmp
  tmp=$(mktemp)
  jq \
    --argjson new_files "$files_json" \
    --arg updated_at "$now" \
    '.files.locked = (.files.locked + $new_files | unique) | .updated_at = $updated_at' \
    "$bf" > "$tmp" && mv "$tmp" "$bf"

  echo "{\"id\":\"${id}\",\"locked\":${files_json}}"
}

cmd_unlock_files() {
  local id="$1"
  shift
  local files=("$@")
  require_bead "$id"

  local bf
  bf=$(bead_file "$id")
  local now
  now=$(now_iso)

  local files_json
  files_json=$(printf '%s\n' "${files[@]}" | jq -R . | jq -s .)

  local tmp
  tmp=$(mktemp)
  jq \
    --argjson rm_files "$files_json" \
    --arg updated_at "$now" \
    '.files.locked = [.files.locked[] | select(. as $f | $rm_files | index($f) | not)] | .updated_at = $updated_at' \
    "$bf" > "$tmp" && mv "$tmp" "$bf"

  echo "{\"id\":\"${id}\",\"unlocked\":${files_json}}"
}

cmd_checkpoint() {
  local id="$1"
  local stage="$2"
  local data="${3:-{}}"
  require_bead "$id"

  local bf
  bf=$(bead_file "$id")
  local now
  now=$(now_iso)

  local tmp
  tmp=$(mktemp)
  jq \
    --arg stage "$stage" \
    --arg timestamp "$now" \
    --argjson data "$data" \
    --arg updated_at "$now" \
    '.checkpoints += [{"stage": $stage, "timestamp": $timestamp, "data": $data}] | .updated_at = $updated_at' \
    "$bf" > "$tmp" && mv "$tmp" "$bf"

  echo "{\"id\":\"${id}\",\"checkpoint\":\"${stage}\"}"
}

cmd_close() {
  local id="$1"
  shift
  local pr_url=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pr-url) pr_url="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  require_bead "$id"

  local bf
  bf=$(bead_file "$id")
  local now
  now=$(now_iso)

  # Update status to closed
  local tmp
  tmp=$(mktemp)
  if [[ -n "$pr_url" ]]; then
    jq \
      --arg status "closed" \
      --arg updated_at "$now" \
      --arg closed_at "$now" \
      --arg pr_url "$pr_url" \
      '.status = $status | .updated_at = $updated_at | .closed_at = $closed_at | .pr_url = $pr_url | .files.locked = []' \
      "$bf" > "$tmp" && mv "$tmp" "$bf"
  else
    jq \
      --arg status "closed" \
      --arg updated_at "$now" \
      --arg closed_at "$now" \
      '.status = $status | .updated_at = $updated_at | .closed_at = $closed_at | .files.locked = []' \
      "$bf" > "$tmp" && mv "$tmp" "$bf"
  fi

  # Move to archive
  local src_dir
  src_dir=$(bead_dir "$id")
  local dest_dir="${ARCHIVE_DIR}/${id}"
  mv "$src_dir" "$dest_dir"

  echo "{\"id\":\"${id}\",\"status\":\"closed\",\"archived\":true}"
}

cmd_list_active() {
  local beads=()
  for dir in "${ACTIVE_DIR}"/forge-*; do
    [[ -d "$dir" ]] || continue
    local bf="${dir}/bead.json"
    [[ -f "$bf" ]] || continue
    beads+=("$(jq -c '{id:.id, title:.title, status:.status, riskTier:.riskTier, mode:.mode, created_at:.created_at}' "$bf")")
  done

  if [[ ${#beads[@]} -eq 0 ]]; then
    echo "[]"
  else
    printf '%s\n' "${beads[@]}" | jq -s '.'
  fi
}

cmd_check_file() {
  local file="$1"
  local self_id="${2:-}"

  for dir in "${ACTIVE_DIR}"/forge-*; do
    [[ -d "$dir" ]] || continue
    local bf="${dir}/bead.json"
    [[ -f "$bf" ]] || continue

    local bead_id
    bead_id=$(jq -r '.id' "$bf")

    local is_locked
    is_locked=$(jq --arg f "$file" '.files.locked | index($f) != null' "$bf")

    if [[ "$is_locked" == "true" ]]; then
      if [[ "$bead_id" == "$self_id" ]]; then
        jq -n --arg state "locked_by_self" --arg owner "$bead_id" '{state:$state, owner:$owner}'
        return
      else
        jq -n --arg state "locked_by_other" --arg owner "$bead_id" '{state:$state, owner:$owner}'
        return
      fi
    fi
  done

  jq -n --arg state "unlocked" '{state:$state, owner:null}'
}

cmd_get() {
  local id="$1"
  require_bead "$id"
  cat "$(bead_file "$id")"
}

# --- Dispatch ---

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  create)       cmd_create "$@" ;;
  transition)   cmd_transition "$@" ;;
  lock-files)   cmd_lock_files "$@" ;;
  unlock-files) cmd_unlock_files "$@" ;;
  checkpoint)   cmd_checkpoint "$@" ;;
  close)        cmd_close "$@" ;;
  list-active)  cmd_list_active ;;
  check-file)   cmd_check_file "$@" ;;
  get)          cmd_get "$@" ;;
  *)
    echo "{\"error\":\"Unknown command: ${COMMAND}. Valid: create, transition, lock-files, unlock-files, checkpoint, close, list-active, check-file, get\"}" >&2
    exit 1
    ;;
esac
