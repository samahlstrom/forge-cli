{
	"name": "forge-cli",
	"version": "0.1.0",
	"description": "Agent harness scaffolding for Claude Code — orchestration, decomposition, specialist agents, verification, and delivery.",
	"type": "module",
	"bin": {
		"forge": "./bin/forge.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint src/",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"bin/",
		"dist/",
		"templates/"
	],
	"keywords": [
		"claude-code",
		"agent",
		"harness",
		"orchestration",
		"ai",
		"cli",
		"scaffold"
	],
	"author": "",
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@clack/prompts": "^0.9.1",
		"chalk": "^5.4.1",
		"commander": "^13.1.0",
		"execa": "^9.5.2",
		"yaml": "^2.7.1"
	},
	"devDependencies": {
		"@types/node": "^22.15.0",
		"typescript": "^5.8.3",
		"vitest": "^3.1.1"
	}
}
